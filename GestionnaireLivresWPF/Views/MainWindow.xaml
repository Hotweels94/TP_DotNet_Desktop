<Window x:Class="GestionnaireLivresWPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="📚 Gestionnaire de Livres"
        WindowStartupLocation="CenterScreen"
        Width="1500"
        Height="800"
        MinWidth="1200"
        MinHeight="850"
        Background="#F5F6FA"
        FontFamily="Segoe UI">

	<Grid Margin="24">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<Border Grid.Row="0"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18"
                Margin="0,0,0,18"
                SnapsToDevicePixels="True">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="420"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<TextBlock Grid.Column="0"
                           Text="Recherche :"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>

				<TextBox Grid.Column="1"
                         Height="44"
                         VerticalContentAlignment="Center"
                         FontSize="16"
                         Padding="10,0"
                         BorderBrush="#D1D5DB"
                         Background="#FAFAFA"
                         Text="{Binding TermeRecherche, UpdateSourceTrigger=PropertyChanged}"/>

				<TextBlock Grid.Column="2"
                           Text="Tape un titre ou un auteur"
                           VerticalAlignment="Center"
                           Margin="18,0,0,0"
                           Foreground="#9CA3AF"
                           FontSize="14"/>
			</Grid>
		</Border>


		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="430"/>
				<ColumnDefinition Width="24"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="20">

				<Grid>

					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<TextBlock Grid.Row="0"
                               Text="Gestion du livre"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,0,0,20"
                               Foreground="#111827"/>


					<StackPanel Grid.Row="1" Margin="0,0,0,14">
						<TextBlock Text="Titre"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   Margin="0,0,0,6"/>
						<TextBox Height="42"
                                 FontSize="15"
                                 Padding="10,0"
                                 Background="#FAFAFA"
                                 BorderBrush="#D1D5DB"
                                 Text="{Binding Titre, UpdateSourceTrigger=PropertyChanged}"/>
					</StackPanel>

					<StackPanel Grid.Row="2" Margin="0,0,0,14">
						<TextBlock Text="Auteur"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   Margin="0,0,0,6"/>
						<TextBox Height="42"
                                 FontSize="15"
                                 Padding="10,0"
                                 Background="#FAFAFA"
                                 BorderBrush="#D1D5DB"
                                 Text="{Binding Auteur, UpdateSourceTrigger=PropertyChanged}"/>
					</StackPanel>

					<StackPanel Grid.Row="3" Margin="0,0,0,14">
						<TextBlock Text="Année"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   Margin="0,0,0,6"/>
						<TextBox Height="42"
                                 FontSize="15"
                                 Padding="10,0"
                                 Background="#FAFAFA"
                                 BorderBrush="#D1D5DB"
                                 Text="{Binding Annee, UpdateSourceTrigger=PropertyChanged}"/>
					</StackPanel>

					<StackPanel Grid.Row="4" Margin="0,0,0,14">
						<TextBlock Text="Genre"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   Margin="0,0,0,6"/>
						<ComboBox Height="42"
                                  FontSize="15"
                                  Background="#FAFAFA"
                                  ItemsSource="{Binding Genres}"
                                  SelectedItem="{Binding Genre, UpdateSourceTrigger=PropertyChanged}"/>
					</StackPanel>

					<CheckBox Grid.Row="5"
                              Content="Livre lu"
                              FontSize="15"
                              Margin="0,6,0,18"
                              Foreground="#374151"/>


					<Grid Grid.Row="6" Margin="0,0,0,12">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Button Grid.Column="0"
                                Content="Ajouter"
                                Height="48"
                                FontSize="16"
                                FontWeight="Bold"
                                Command="{Binding AjouterCommand}"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"/>

						<Button Grid.Column="2"
                                Content="Modifier"
                                Height="48"
                                FontSize="16"
                                FontWeight="Bold"
                                Command="{Binding ModifierCommand}"
                                Background="#16A34A"
                                Foreground="White"
                                BorderThickness="0"/>
					</Grid>

					<StackPanel Grid.Row="7">

						<Button Content="Supprimer"
                                Height="48"
                                FontSize="16"
                                FontWeight="Bold"
                                Command="{Binding SupprimerCommand}"
                                Background="#DC2626"
                                Foreground="White"
                                BorderThickness="0"
                                Margin="0,0,0,14"/>

						<TextBlock Text="💡 Sélectionne une ligne du tableau pour modifier un livre"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   Foreground="#6B7280"/>
					</StackPanel>

				</Grid>
			</Border>

			<Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="20">

				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<TextBlock Grid.Row="0"
                               Text="Liste des livres"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,0,0,16"
                               Foreground="#111827"/>

					<DataGrid Grid.Row="1"
                              ItemsSource="{Binding Livres}"
                              SelectedItem="{Binding LivreSelectionne, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              FontSize="15"
                              RowHeight="38"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0">

						<DataGrid.Columns>
							<DataGridTextColumn Header="Titre" Binding="{Binding Titre}" Width="2*"/>
							<DataGridTextColumn Header="Auteur" Binding="{Binding Auteur}" Width="2*"/>
							<DataGridTextColumn Header="Année" Binding="{Binding Annee}" Width="*"/>
							<DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="*"/>
							<DataGridCheckBoxColumn Header="Lu" Binding="{Binding Lu}" Width="*"/>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>
			</Border>

		</Grid>

		<Border Grid.Row="2"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18"
                Margin="0,18,0,0">

			<TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#111827">
				<Run Text="{Binding TotalLivres}"/>
				<Run Text=" livre(s) | "/>
				<Run Text="{Binding LivresLus}"/>
				<Run Text=" lu(s) | "/>
				<Run Text="{Binding PourcentageLus}"/>
				<Run Text="% complétés"/>
			</TextBlock>

		</Border>

	</Grid>
</Window>